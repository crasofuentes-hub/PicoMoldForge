{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/crasofuentes-hub/PicoMoldForge/schemas/picomoldforge.run-manifest.schema.json",
  "title": "PicoMoldForge Run Manifest",
  "description": "JSON schema for RunManifest.json generated by PicoMoldForge.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "SchemaVersion",
    "GeneratedAtUtc",
    "ProjectName",
    "ConfigPath",
    "OutputDirectory",
    "FinalReportPath",
    "CleanOutput",
    "UsedOutputOverride",
    "Artifacts",
    "Warnings"
  ],
  "properties": {
    "SchemaVersion": {
      "type": "string",
      "const": "picomoldforge.run-manifest.v1"
    },
    "GeneratedAtUtc": {
      "type": "string",
      "format": "date-time"
    },
    "ProjectName": {
      "type": "string",
      "minLength": 1
    },
    "ConfigPath": {
      "type": "string",
      "minLength": 1
    },
    "OutputDirectory": {
      "type": "string",
      "minLength": 1
    },
    "FinalReportPath": {
      "type": "string",
      "minLength": 1
    },
    "CleanOutput": {
      "type": "boolean"
    },
    "UsedOutputOverride": {
      "type": "boolean"
    },
    "OutputOverridePath": {
      "type": ["string", "null"]
    },
    "Artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "FileName",
          "Path",
          "SizeBytes",
          "Sha256"
        ],
        "properties": {
          "FileName": {
            "type": "string",
            "minLength": 1
          },
          "Path": {
            "type": "string",
            "minLength": 1
          },
          "SizeBytes": {
            "type": "integer",
            "minimum": 1
          },
          "Sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    },
    "Warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}