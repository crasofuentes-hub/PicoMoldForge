{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/crasofuentes-hub/PicoMoldForge/schemas/picomoldforge.final-project-report.schema.json",
  "title": "PicoMoldForge Final Project Report",
  "description": "Permissive JSON schema for FinalProjectReport.json generated by PicoMoldForge. This schema is intentionally tolerant while the report evolves.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "ProjectName"
  ],
  "properties": {
    "SchemaVersion": {
      "type": "string"
    },
    "ProjectName": {
      "type": "string",
      "minLength": 1
    },
    "Warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "GeneratedArtifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}